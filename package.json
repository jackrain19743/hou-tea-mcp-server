{
  "name": "@hou-tea/mcp-server",
  "version": "0.3.0-beta.0",
  "description": "Agent-app MCP server for hou-tea.com — browse / recommend / buy authentic Chinese tea via x402 USDC, with progressive tool discovery, strict JSON Schemas, structured error model, request_id, and next_action hints.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://hou-tea.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hou-tea/hou-tea-mcp-server.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "x402",
    "agent-commerce",
    "chinese-tea",
    "ai-agent",
    "claude",
    "cursor",
    "usdc",
    "stablecoin",
    "agentic-payments"
  ],
  "bin": {
    "hou-tea-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "test:unit": "node tests/unit_response.mjs && node tests/unit_registry.mjs",
    "test:smoke": "tsx tests/smoke.ts",
    "test:mcp": "node tests/mcp_smoke.mjs",
    "test": "npm run build && npm run test:unit"
  },
  "dependencies": {
    "@hou-tea/agent-ui-contract": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
